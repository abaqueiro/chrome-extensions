{
	"manifest_version": 3
	, "name": "myCss"
	, "description": "Change page css"
	, "version": "0.1"
	, "author": {
		"email": "abaqueiro@gmail.com"
	}
	, "content_scripts": [
		{
			"matches": ["https://chat.deepseek.com/*"]
			, "css": ["css/deepseek.css"]
		}
		,{
			"matches": ["https://chatgpt.com/*"]
			, "css": ["css/chatgpt.css"]
		}
		,{
			"matches": ["https://copilot.microsoft.com/*"]
			, "css": ["css/copilot-ms.css"]
		}
		,{
			"matches": ["https://claude.ai/*"]
			, "css": ["css/claude-ai.css"]
		}
		,{
			"matches": ["https://gemini.google.com/*"]
			, "css": ["css/gemini.css"]
		}
		,{
			"matches": ["https://grok.com/*"]
			, "css": ["css/grok.css"]
		}
		,{
			"matches": ["https://perplexity.ai/*", "https://www.perplexity.ai/*"]
			, "css": ["css/perplexity.css"]
		}
	]
}
